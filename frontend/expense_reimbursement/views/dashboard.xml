<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Dashboard View -->
        <record id="view_expense_dashboard" model="ir.ui.view">
            <field name="name">expense.reimbursement.dashboard</field>
            <field name="model">expense.reimbursement</field>
            <field name="arch" type="xml">
                <dashboard string="Expense Dashboard">
                    <view type="form">
                        <sheet>
                            <div class="oe_title">
                                <h1>Expense Reimbursement Dashboard</h1>
                            </div>
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="panel panel-primary">
                                        <div class="panel-heading">
                                            <h3 class="panel-title">Total Expenses</h3>
                                        </div>
                                        <div class="panel-body">
                                            <h2 class="text-center">
                                                <field name="total_expenses" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                            </h2>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="panel panel-warning">
                                        <div class="panel-heading">
                                            <h3 class="panel-title">Pending</h3>
                                        </div>
                                        <div class="panel-body">
                                            <h2 class="text-center">
                                                <field name="pending_count"/>
                                            </h2>
                                            <p class="text-center">
                                                <small>Amount: <field name="pending_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/></small>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="panel panel-success">
                                        <div class="panel-heading">
                                            <h3 class="panel-title">Approved</h3>
                                        </div>
                                        <div class="panel-body">
                                            <h2 class="text-center">
                                                <field name="approved_count"/>
                                            </h2>
                                            <p class="text-center">
                                                <small>Amount: <field name="approved_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/></small>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="panel panel-danger">
                                        <div class="panel-heading">
                                            <h3 class="panel-title">Rejected</h3>
                                        </div>
                                        <div class="panel-body">
                                            <h2 class="text-center">
                                                <field name="rejected_count"/>
                                            </h2>
                                            <p class="text-center">
                                                <small>Amount: <field name="rejected_amount" widget="monetary" options="{'currency_field': 'currency_id'}"/></small>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </sheet>
                    </view>
                    
                    <!-- Charts Section -->
                    <div class="row">
                        <div class="col-md-6">
                            <graph string="Expenses by Status" type="pie">
                                <field name="state"/>
                                <field name="amount" type="measure"/>
                            </graph>
                        </div>
                        <div class="col-md-6">
                            <graph string="Expenses by Month" type="bar">
                                <field name="date" interval="month"/>
                                <field name="amount" type="measure"/>
                            </graph>
                        </div>
                    </div>
                    
                    <!-- Recent Expenses -->
                    <div class="row">
                        <div class="col-md-12">
                            <kanban string="Recent Expenses" limit="10">
                                <field name="employee_id"/>
                                <field name="amount"/>
                                <field name="currency_id"/>
                                <field name="date"/>
                                <field name="state"/>
                                <field name="description"/>
                                <templates>
                                    <t t-name="kanban-box">
                                        <div class="oe_kanban_card oe_kanban_global_click">
                                            <div class="o_kanban_record_top">
                                                <div class="o_kanban_record_headings">
                                                    <strong class="o_kanban_record_title"><field name="employee_id"/></strong>
                                                </div>
                                                <div class="o_kanban_manage_button_section">
                                                    <span class="badge badge-<t t-if="record.state.raw_value == 'approved'">success</t><t t-elif="record.state.raw_value == 'submitted'">warning</t><t t-elif="record.state.raw_value == 'manager_approved'">info</t><t t-elif="record.state.raw_value == 'rejected'">danger</t><t t-else="">secondary</t>">
                                                        <field name="state"/>
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="o_kanban_record_body">
                                                <field name="description"/>
                                                <div class="o_kanban_record_bottom">
                                                    <div class="oe_kanban_bottom_left">
                                                        <strong><field name="amount"/> <field name="currency_id"/></strong>
                                                    </div>
                                                    <div class="oe_kanban_bottom_right">
                                                        <small><field name="date"/></small>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                        </div>
                    </div>
                </dashboard>
            </field>
        </record>

        <!-- Dashboard Action -->
        <record id="action_expense_dashboard" model="ir.actions.act_window">
            <field name="name">Expense Dashboard</field>
            <field name="res_model">expense.reimbursement</field>
            <field name="view_mode">dashboard</field>
            <field name="view_id" ref="view_expense_dashboard"/>
            <field name="target">current</field>
        </record>

        <!-- Dashboard Menu Item -->
        <menuitem id="menu_expense_dashboard_view" name="Dashboard" parent="menu_expense_root" sequence="5" action="action_expense_dashboard"/>
    </data>
</odoo>
