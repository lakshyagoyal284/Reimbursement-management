<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Employee Group -->
        <record id="group_expense_employee" model="res.groups">
            <field name="name">Expense Employee</field>
            <field name="comment">Can create and view own expenses</field>
        </record>

        <!-- Manager Group -->
        <record id="group_expense_manager" model="res.groups">
            <field name="name">Expense Manager</field>
            <field name="comment">Can view team expenses and approve/reject</field>
            <field name="implied_ids" eval="[(4, ref('group_expense_employee'))]"/>
        </record>

        <!-- Admin Group -->
        <record id="group_expense_admin" model="res.groups">
            <field name="name">Expense Admin</field>
            <field name="comment">Can view all expenses and provide final approval</field>
            <field name="implied_ids" eval="[(4, ref('group_expense_manager'))]"/>
        </record>

        <!-- Record Rules -->
        <!-- Employee can only see their own expenses -->
        <record id="rule_expense_employee" model="ir.rule">
            <field name="name">Employee: Own Expenses Only</field>
            <field name="model_id" ref="model_expense_claim"/>
            <field name="domain_force">[('employee_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_expense_employee'))]"/>
        </record>

        <!-- Manager can see expenses of their team members -->
        <record id="rule_expense_manager" model="ir.rule">
            <field name="name">Manager: Team Expenses</field>
            <field name="model_id" ref="model_expense_claim"/>
            <field name="domain_force">['|', ('employee_id', '=', user.id), ('manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_expense_manager'))]"/>
        </record>

        <!-- Admin can see all expenses -->
        <record id="rule_expense_admin" model="ir.rule">
            <field name="name">Admin: All Expenses</field>
            <field name="model_id" ref="model_expense_claim"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_expense_admin'))]"/>
        </record>
    </data>
</odoo>
